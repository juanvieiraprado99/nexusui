{
  "name": "nexus-ui",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "libs/*",
    "packages/*"
  ],
  "scripts": {
    "start": "concurrently \"npx nx serve web\" \"npx nx run web:tailwind-watch\" \"npm run build:registry:watch\"",
    "dev:cli": "npx tsc -p packages/cli/tsconfig.json && node scripts/inject-registry-url.js http://localhost:4222/r && cd packages/cli && npm link",
    "build:cli": "npx tsc -p packages/cli/tsconfig.json && node scripts/inject-registry-url.js https://nexus-ui.dev/r",
    "generate:component": "nx g ./tools/generators/component:component",
    "build:registry": "npx tsx scripts/build-registry.cts",
    "build:registry:watch": "npx tsx --watch scripts/build-registry.cts"
  },
  "devDependencies": {
    "@angular-devkit/core": "~21.2.0",
    "@angular-devkit/schematics": "~21.2.0",
    "@angular/build": "~21.2.0",
    "@angular/cli": "~21.2.0",
    "@angular/compiler-cli": "~21.2.0",
    "@angular/language-service": "~21.2.0",
    "@eslint/js": "^10.0.1",
    "@nx/angular": "^22.0.0",
    "@nx/devkit": "22.6.5",
    "@nx/eslint": "^22.0.0",
    "@nx/eslint-plugin": "^22.6.5",
    "@nx/js": "22.6.5",
    "@nx/node": "^22.0.0",
    "@nx/playwright": "22.6.5",
    "@nx/web": "22.6.5",
    "@nx/workspace": "^22.0.0",
    "@oxc-project/runtime": "^0.115.0",
    "@playwright/test": "^1.36.0",
    "@schematics/angular": "~21.2.0",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@tailwindcss/cli": "^4.2.4",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/express": "^4.17.21",
    "@types/node": "20.19.9",
    "@typescript-eslint/utils": "^8.40.0",
    "angular-eslint": "^21.2.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.0.0",
    "eslint": "^10.2.1",
    "eslint-plugin-playwright": "^1.6.2",
    "jsdom": "^27.1.0",
    "jsonc-eslint-parser": "^2.1.0",
    "ng-packagr": "~21.2.0",
    "nx": "^22.0.0",
    "postcss": "^8.4.5",
    "prettier": "~3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "tailwindcss": "^4.2.4",
    "tslib": "^2.3.0",
    "typescript": "~5.9.0",
    "vitest": "^4.0.8"
  },
  "dependencies": {
    "@angular-devkit/build-angular": "~21.2.0",
    "@angular/cdk": "^21.2.8",
    "@angular/common": "~21.2.0",
    "@angular/compiler": "~21.2.0",
    "@angular/core": "~21.2.0",
    "@angular/forms": "~21.2.0",
    "@angular/platform-browser": "~21.2.0",
    "@angular/platform-server": "~21.2.0",
    "@angular/router": "~21.2.0",
    "@angular/ssr": "~21.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "express": "^4.21.2",
    "marked": "^18.0.2",
    "rxjs": "~7.8.0",
    "tailwind-merge": "^3.5.0"
  }
}
